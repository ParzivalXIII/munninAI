# =============================================================================
# Forge - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Cognee Cloud Configuration
# -----------------------------------------------------------------------------
# Get your API key from: https://platform.cognee.ai
COGNEE_SERVICE_URL="https://api.cognee.ai"
COGNEE_API_KEY="your-cognee-cloud-api-key-here"

# -----------------------------------------------------------------------------
# LLM Configuration (used by Cognee Cloud)
# -----------------------------------------------------------------------------
# Default: OpenAI GPT-4o-mini (cost-effective for knowledge graph extraction)
LLM_PROVIDER="openai"
LLM_MODEL="openai/gpt-4o-mini"
LLM_API_KEY="your-openai-api-key-here"
LLM_TEMPERATURE="0.0"

# Embedding Configuration
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="openai/text-embedding-3-large"
EMBEDDING_DIMENSIONS="3072"

# -----------------------------------------------------------------------------
# Forge Application Configuration
# -----------------------------------------------------------------------------
# Application settings
FORGE_ENV="development"
FORGE_LOG_LEVEL="INFO"
FORGE_DATA_DIR="./data"

# Web UI settings
FORGE_WEB_HOST="0.0.0.0"
FORGE_WEB_PORT="8000"

# -----------------------------------------------------------------------------
# Dataset Configuration
# -----------------------------------------------------------------------------
# Paths to synthetic datasets (relative to project root)
INCIDENTS_DATA_PATH="./data/incidents.json"
ARCHITECTURE_DATA_PATH="./data/architecture.json"
POSTMORTEM_DATA_PATH="./data/postmortems.json"

# -----------------------------------------------------------------------------
# Rate Limiting (optional, for cost control)
# -----------------------------------------------------------------------------
# LLM_RATE_LIMIT_ENABLED="true"
# LLM_RATE_LIMIT_REQUESTS="60"
# LLM_RATE_LIMIT_INTERVAL="60"

# EMBEDDING_RATE_LIMIT_ENABLED="true"
# EMBEDDING_RATE_LIMIT_REQUESTS="60"
# EMBEDDING_RATE_LIMIT_INTERVAL="60"
